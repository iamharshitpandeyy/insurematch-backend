# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/insurematch

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Legacy token expiration (for backward compatibility)
JWT_EXPIRES_IN=15m

# Email Configuration (SMTP)
# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate an app-specific password
# 3. Use smtp.gmail.com as EMAIL_HOST
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@insurematch.com

# For development/testing without email: Leave EMAIL_HOST empty
# Verification codes will be logged to the console

# Frontend Configuration (for invitation links)
FRONTEND_URL=http://localhost:3000

# Initial Platform Admin Setup (for seed script)
# These are used by: npm run seed:admin
ADMIN_EMAIL=admin@insurematch.com
ADMIN_PASSWORD=AdminPass123
ADMIN_NAME=Platform Admin
